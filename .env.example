# =============================================================================
# 高考志愿智能规划师 - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值

# 模型API配置 (OpenAI 兼容接口)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 服务端口
PORT=8000

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
